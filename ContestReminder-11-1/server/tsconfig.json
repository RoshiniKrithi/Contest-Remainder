{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "commonjs",
    "target": "es2019",
    "esModuleInterop": true,
    "strict": false,
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "dist"]
}
